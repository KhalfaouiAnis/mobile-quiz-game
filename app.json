{
  "expo": {
    "name": "kahoot",
    "slug": "kahoot",
    "version": "1.0.0",
    "scheme": "kahoot",
    "newArchEnabled": true,
    "orientation": "landscape",
    "userInterfaceStyle": "automatic",
    "plugins": [
      [
        "@react-native-tvos/config-tv",
        {
          "androidTVBanner": "./assets/tv_icons/icon-400x240.png",
          "appleTVImages": {
            "icon": "./assets/tv_icons/icon-1280x768.png",
            "iconSmall": "./assets/tv_icons/icon-400x240.png",
            "iconSmall2x": "./assets/tv_icons/icon-800x480.png",
            "topShelf": "./assets/tv_icons/icon-1920x720.png",
            "topShelf2x": "./assets/tv_icons/icon-3840x1440.png",
            "topShelfWide": "./assets/tv_icons/icon-2320x720.png",
            "topShelfWide2x": "./assets/tv_icons/icon-4640x1440.png"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-navigation-bar",
        {
          "visibility": "hidden",
          "behavior": "overlay-swipe"
        }
      ],
      "expo-router",
      "expo-font",
      "expo-build-properties",
      "expo-web-browser",
      [
        "@react-native-google-signin/google-signin",
        {
          "androidClientId": "your-android-client-id.googleusercontent.com",
          "iosClientId": "your-ios-client-id.googleusercontent.com",
          "iosUrlScheme": "com.googleusercontent.apps.ios-url-schema"
        }
      ],
      [
        "react-native-fbsdk-next",
        {
          "appID": "1277409807481340",
          "clientToken": "your-client-token",
          "displayName": "Xcars",
          "scheme": "fb{your-app-id}",
          "advertiserIDCollectionEnabled": false,
          "autoLogAppEventsEnabled": false,
          "installAutoInitEnabled": true
        }
      ],
      "expo-apple-authentication",
      "expo-video",
      "expo-audio",
      "react-native-compressor"
    ],
    "android": {
      "systemBars": {
        "statusBar": {
          "hidden": true
        }
      },
      "windowSoftInputMode": "adjustResize",
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "edgeToEdgeEnabled": true,
      "splash": {
        "image": "./assets/images/splash.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.aniskhalfaoui.kahoot"
    },
    "ios": {
      "usesAppleSignIn": true,
      "splash": {
        "image": "./assets/images/splash.png"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png",
      "output": "static"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "supportsRTL": true
    }
  }
}
